# ---------------------------------------------------------------------------
# Household Expense Tracker - configuration
# Copy this file to ".env" and adjust. All keys are optional; sensible
# defaults are used when a value is missing.
# ---------------------------------------------------------------------------

# Which storage backend to use: "local" (browser) or "googleSheets".
# "googleSheets" is a stub today - see src/services/storage/GoogleSheetsRepository.ts
VITE_STORAGE_PROVIDER=local

# Currency + locale used to format money everywhere in the app.
VITE_CURRENCY=USD
VITE_LOCALE=en-US

# App title shown in the header.
VITE_APP_NAME=Household Expense Tracker

# --- Google Sheets (only used when VITE_STORAGE_PROVIDER=googleSheets) -------
# The spreadsheet ID and the API base of whatever backend/proxy you wire up.
VITE_GOOGLE_SHEETS_ID=
VITE_GOOGLE_SHEETS_API_BASE=
