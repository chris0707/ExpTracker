{
  "name": "household-expense-tracker",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A friendly household expense tracker built with React. PIN login, dynamic members, categories, and CSV records. Designed to beat a spreadsheet.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:portable": "tsc --noEmit && vite build --mode portable",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.0.5"
  }
}
